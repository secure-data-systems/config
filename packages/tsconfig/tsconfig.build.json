{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"declaration": true,
		"lib": ["ES2024", "DOM"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"noUncheckedIndexedAccess": true,
		"resolveJsonModule": true,
		"strict": true,
		"target": "esnext",
		"types": ["node"]
	},
	"exclude": ["test.js", "dist", "**/*.spec.ts", "test"]
}
